# ─────────────────────────────────────────────────────────
#  HashKey PayLink — Environment Variables
# ─────────────────────────────────────────────────────────
#  Get a free WalletConnect Project ID at:
#  https://cloud.walletconnect.com
#
#  Without it, WalletConnect modal won't open, but
#  MetaMask (browser injected wallet) still works fine.
# ─────────────────────────────────────────────────────────

VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ─────────────────────────────────────────────────────────
#  V2 Direct Send (ghost-vault / sponsored relayer)
# ─────────────────────────────────────────────────────────
#  Deployed PayLinkFactoryV2 on Base mainnet.
#  Set both — VITE_ prefix makes it available to the browser.
VITE_FACTORY_V2=0x706C84aB768DBf60a84b717e4c49498BEf78b0cD
PAYLINK_FACTORY_V2=0x706C84aB768DBf60a84b717e4c49498BEf78b0cD

#  Deployed PayLinkFactoryV2 on Arc Testnet (chainId 5042002).
#  USDC on Arc: native precompile at 0x3600000000000000000000000000000000000000
VITE_FACTORY_V2_ARC=0x6026ce46761A164CFC7ea268F722BBDfe6E8a706
PAYLINK_FACTORY_V2_ARC=0x6026ce46761A164CFC7ea268F722BBDfe6E8a706

#  Relayer wallet private key (0x-prefixed).
#  Same as your deployer wallet — signs relay() calls, pays gas.
#  NEVER expose this to the browser (no VITE_ prefix).
RELAYER_PRIVATE_KEY=0x_your_deployer_private_key_here

#  High-rate-limit RPC for the backend relayer (Alchemy / QuickNode).
#  NEVER expose this to the browser.
PRIVATE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_backend_key

#  Arc testnet RPC (public — no key needed).
PRIVATE_RPC_URL_ARC=https://rpc.testnet.arc.network
#  Arc relayer key — must be the wallet registered as relayer on the Arc factory.
#  This wallet must hold Arc native USDC for gas. Falls back to RELAYER_PRIVATE_KEY.
RELAYER_PRIVATE_KEY_ARC=0x_arc_deployer_private_key_here

# ─────────────────────────────────────────────────────────
#  Arbitrum + GHO (relay-gho.ts + relay-v2.ts arbitrum case)
# ─────────────────────────────────────────────────────────
#  Relayer wallet on Arbitrum One. Needs a small ETH balance for gas
#  (~$5 covers thousands of GHO relays at Arbitrum's cheap gas rates).
#  Falls back to RELAYER_PRIVATE_KEY if unset.
RELAYER_PRIVATE_KEY_ARB=0x_arbitrum_relayer_private_key_here

#  Arbitrum One RPC — use Alchemy/QuickNode for production, public for testing.
PRIVATE_RPC_URL_ARB=https://arb1.arbitrum.io/rpc

#  Deployed PayLinkFactoryV2 on Arbitrum One (Send via Address / vault relay).
#  Deploy with: npx hardhat run scripts/deploy-factory-deterministic.ts --network arbitrum
#  Server-side only (no VITE_ prefix) — used by relay-v2.ts.
PAYLINK_FACTORY_V2_ARB=0x_your_arbitrum_factory_address_here

#  Same factory address exposed to the browser for CREATE2 vault address computation.
VITE_FACTORY_V2_ARB=0x_your_arbitrum_factory_address_here

#  Public RPC for browser-side USDC balance polling (Alchemy).
#  VITE_ prefix makes it available to Vite's client bundle.
VITE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_frontend_key

#  Arc testnet factory address for the browser bundle.
VITE_FACTORY_V2_ARC=0x6026ce46761A164CFC7ea268F722BBDfe6E8a706

# ─────────────────────────────────────────────────────────
#  Streampay Module — Arc Network
# ─────────────────────────────────────────────────────────
#  Deployed StreamVaultFactory on Arc Testnet (chainId 5042002).
#  Deploy with: npx hardhat run modules/streampay/scripts/deploy.ts --network arc
STREAM_FACTORY_ADDRESS=0x05e621a4d9860a0066d29b7ed376fb926d5a773e

#  Browser-accessible factory address (VITE_ prefix exposes it to the frontend).
#  Used by StreamView to pre-compute vault addresses client-side via CREATE2.
#  Must match STREAM_FACTORY_ADDRESS exactly.
VITE_STREAM_FACTORY_ADDRESS=0x05e621a4d9860a0066d29b7ed376fb926d5a773e

#  Arc relayer key and RPC are shared with the InstantPay V2 relayer.
#  These are already declared above (RELAYER_PRIVATE_KEY_ARC, PRIVATE_RPC_URL_ARC).
#  The relay-stream handler falls back to RELAYER_PRIVATE_KEY if the ARC variant is unset.

# ─────────────────────────────────────────────────────────
#  Starknet Relayer (recover-starknet / setup-relayer)
# ─────────────────────────────────────────────────────────
#  OpenZeppelin Account deployed on Starknet Mainnet.
#  Fund with STRK for gas before calling /api/setup-starknet-relayer.
#  NEVER use the VITE_ prefix — these must stay server-side only.
STARKNET_RELAYER_ADDRESS=0x_your_starknet_relayer_address_here
STARKNET_RELAYER_PRIVATE_KEY=0x_your_starknet_relayer_private_key_here

#  OZ Account class hash — defaults to v0.8.1 if unset.
#  Only override if you deploy a different account class.
STARKNET_OZ_CLASS_HASH=0x061dac032f228abef9c6626f995015233097ae253a7f72d68552db02f2971b8f

#  Starknet RPC endpoint — defaults to public Lava node if unset.
#  Use a private endpoint (Infura / Blast) for higher rate limits.
STARKNET_RPC_URL=https://rpc.starknet.lava.build

# ─────────────────────────────────────────────────────────
#  Sweep Keeper (sweep-keeper / sweep)
# ─────────────────────────────────────────────────────────
#  Wallet that pays Base ETH gas for batch ghost-vault sweeps.
#  Does NOT need to hold USDC — it only submits the relay() call.
KEEPER_PRIVATE_KEY=0x_your_keeper_private_key_here

#  Secret passed as ?secret= query param to authenticate cron requests.
#  Set to any long random string (e.g. openssl rand -hex 32).
CRON_SECRET=your_random_cron_secret_here

#  Block number the PayLinkFactoryV2 was deployed at on Base mainnet.
#  Limits event log scans — defaults to 29500000 if unset.
FACTORY_FROM_BLOCK=29500000
