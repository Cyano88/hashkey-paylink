# ─────────────────────────────────────────────────────────
#  HashKey PayLink — Environment Variables
# ─────────────────────────────────────────────────────────
#  Get a free WalletConnect Project ID at:
#  https://cloud.walletconnect.com
#
#  Without it, WalletConnect modal won't open, but
#  MetaMask (browser injected wallet) still works fine.
# ─────────────────────────────────────────────────────────

VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ─────────────────────────────────────────────────────────
#  V2 Direct Send (ghost-vault / sponsored relayer)
# ─────────────────────────────────────────────────────────
#  Deployed PayLinkFactoryV2 on Base mainnet.
#  Set both — VITE_ prefix makes it available to the browser.
VITE_FACTORY_V2=0x706C84aB768DBf60a84b717e4c49498BEf78b0cD
PAYLINK_FACTORY_V2=0x706C84aB768DBf60a84b717e4c49498BEf78b0cD

#  Relayer wallet private key (0x-prefixed).
#  Same as your deployer wallet — signs relay() calls, pays gas.
#  NEVER expose this to the browser (no VITE_ prefix).
RELAYER_PRIVATE_KEY=0x_your_deployer_private_key_here

#  High-rate-limit RPC for the backend relayer (Alchemy / QuickNode).
#  NEVER expose this to the browser.
PRIVATE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_backend_key

#  Public RPC for browser-side USDC balance polling (Alchemy).
#  VITE_ prefix makes it available to Vite's client bundle.
VITE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_frontend_key
