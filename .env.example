# ─────────────────────────────────────────────────────────
#  HashKey PayLink — Environment Variables
# ─────────────────────────────────────────────────────────
#  Get a free WalletConnect Project ID at:
#  https://cloud.walletconnect.com
#
#  Without it, WalletConnect modal won't open, but
#  MetaMask (browser injected wallet) still works fine.
# ─────────────────────────────────────────────────────────

VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here
VITE_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_CIRCLE_LINK_STORE=./data/privy-circle-links.json

# Durable server-side storage for Circle wallet mappings, agent subscriptions,
# and Nigerian POS merchant QR profiles. Required on Render if POS QR links must
# survive deploys/restarts.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
NG_POS_STORE_KEY=hashpaylink:ng-pos-merchants
EVENT_REGISTRY_STORE_KEY=hashpaylink:event-registry
# legacy = RainbowKit/Circle native frontend auth only
# hybrid = enable PrivyProvider while legacy wallet UI remains available
VITE_AUTH_BRIDGE=legacy

# Optional Base connected-wallet gas sponsorship via Coinbase/CDP Paymaster.
# Keep the real CDP URL server-side; expose only this same-origin proxy path.
VITE_BASE_PAYMASTER_URL=/api/base-paymaster
CDP_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base/YOUR_CDP_PAYMASTER_KEY

# Optional Circle Paymaster architecture.
# Disabled until the ERC-4337/EIP-7702 user-operation payment path is wired.
# Circle Paymaster charges gas in USDC on supported EVM chains; it does not
# sponsor the merchant payment amount and does not custody funds.
VITE_CIRCLE_PAYMASTER_ENABLED=false
VITE_CIRCLE_BUNDLER_URL_BASE=https://public.pimlico.io/v2/8453/rpc
VITE_CIRCLE_BUNDLER_URL_ARB=https://public.pimlico.io/v2/42161/rpc
# Override only if Circle rotates the v0.8 paymaster address.
VITE_CIRCLE_PAYMASTER_V08_BASE=0x0578cFB241215b77442a541325d6A4E6dFE700Ec
VITE_CIRCLE_PAYMASTER_V08_ARB=0x0578cFB241215b77442a541325d6A4E6dFE700Ec

# Circle Modular Wallets passkey login for "Continue with email" gasless pay.
# Public browser credentials from Circle Modular Wallet Console Setup.
VITE_CLIENT_KEY=
VITE_CLIENT_URL=

# Circle User-Controlled Wallets for email receive/pay flows.
# This is separate from Modular Wallets. CIRCLE_API_KEY stays server-side;
# VITE_CIRCLE_USER_WALLET_APP_ID is the public Wallet App ID.
# Arc Testnet requires Circle testnet credentials.
VITE_CIRCLE_USER_WALLET_APP_ID=
VITE_CIRCLE_USER_WALLET_APP_ID_ARC_TESTNET=
CIRCLE_API_KEY=
CIRCLE_TEST_API_KEY=
CIRCLE_BASE_URL=https://api.circle.com
CIRCLE_SOLANA_BLOCKCHAIN=SOL

# Optional Circle Agent Wallet provisioning on /agent.
# Requires Circle CLI installed in the web runtime: npm install -g @circle-fin/cli
CIRCLE_CLI_ENABLED=false
AGENT_WALLET_PROVISION_STORE=./data/agent-wallet-provisioning.json
# Platform-pinned agent wallets are public lookup records and cannot be replaced
# from the external agent setup flow. External agents still register into the store.
DEFAULT_AGENT_SLUG=hashpaylink-agent
DEFAULT_AGENT_WALLET_ADDRESS=
# Optional JSON map for additional pinned agents:
# {"research-agent":{"walletAddress":"0x...","chain":"ARC-TESTNET"}}
AGENT_WALLET_REGISTRY=

# Optional Circle Gateway x402 seller endpoint for machine-to-machine agent payments.
X402_SELLER_ADDRESS=
X402_POLYMARKET_SCOUT_PRICE=$0.01
X402_FACILITATOR_URL=https://gateway-api-testnet.circle.com
AGENT_WALLET_SERVICE_SECRET=
AGENT_WALLET_ALLOWED_SERVICE_URLS=https://hashpaylink.com/api/x402/polymarket-scout
AGENT_WALLET_MAX_SERVICE_AMOUNT=0.01

# Starknet embedded/email smart wallet via Argent Invisible SDK.
# This is browser-visible configuration only. Mainnet session scopes must be
# whitelisted by Argent for the USDC transfer method before enabling publicly.
VITE_STARKNET_EMAIL_WALLET_ENABLED=false
VITE_ARGENT_APP_NAME=Hash PayLink
VITE_ARGENT_ENVIRONMENT=mainnet
VITE_ARGENT_SESSION_DAYS=7
VITE_AVNU_STARKNET_PAYMASTER_URL=https://starknet.paymaster.avnu.fi

# ─────────────────────────────────────────────────────────
#  0G Storage — decentralized payment record archive
#  Chain ID: 16661 | Explorer: chainscan.0g.ai
# ─────────────────────────────────────────────────────────
#  Private key of wallet holding OG tokens (for storage gas).
#  Falls back to RELAYER_PRIVATE_KEY if not set.
OG_STORAGE_KEY=0x_your_og_wallet_private_key

#  Deployed PayLinkArchive contract on 0G Mainnet.
#  Deploy: npx hardhat run scripts/deploy-og-archive.ts --network og
OG_ARCHIVE_ADDRESS=0x_deployed_paylink_archive_address

# ─────────────────────────────────────────────────────────
#  V2 Direct Send (ghost-vault / sponsored relayer)
# ─────────────────────────────────────────────────────────
#  PayLinkFactoryV2 — deployed via Nick's Method, same address on ALL EVM chains.
#  Deployer/relayer/owner: 0x51080f31A21BeDafe50180944606044C12Ea88E4
#  Base USDC:    0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
#  Arc USDC:     0x3600000000000000000000000000000000000000
#  Arbitrum USDC: 0xaf88d065e77c8cC2239327C5EDb3A432268e5831
VITE_FACTORY_V2=0x2268B8aad138a550FEf46C621756fEb26b587F78
PAYLINK_FACTORY_V2=0x2268B8aad138a550FEf46C621756fEb26b587F78
VITE_FACTORY_V2_ARC=0x2268B8aad138a550FEf46C621756fEb26b587F78
PAYLINK_FACTORY_V2_ARC=0x2268B8aad138a550FEf46C621756fEb26b587F78

#  Relayer wallet private key (0x-prefixed).
#  Wallet: 0x51080f31A21BeDafe50180944606044C12Ea88E4
#  NEVER expose this to the browser (no VITE_ prefix).
RELAYER_PRIVATE_KEY=0x_your_relayer_private_key_here

#  High-rate-limit RPC for the backend relayer (Alchemy / QuickNode).
#  NEVER expose this to the browser.
PRIVATE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_backend_key

#  Arc testnet RPC (public — no key needed).
PRIVATE_RPC_URL_ARC=https://rpc.testnet.arc.network
#  Arc relayer key — must be the wallet registered as relayer on the Arc factory.
#  This wallet must hold Arc native USDC for gas. Falls back to RELAYER_PRIVATE_KEY.
RELAYER_PRIVATE_KEY_ARC=0x_arc_deployer_private_key_here

# ─────────────────────────────────────────────────────────
#  Arbitrum + native USDC (relay-gho.ts + relay-v2.ts arbitrum case)
# ─────────────────────────────────────────────────────────
#  Relayer wallet on Arbitrum One. Needs a small ETH balance for gas
#  (~$5 covers thousands of USDC relays at Arbitrum's cheap gas rates).
#  Falls back to RELAYER_PRIVATE_KEY if unset.
RELAYER_PRIVATE_KEY_ARB=0x_arbitrum_relayer_private_key_here

#  Arbitrum One RPC — use Alchemy/QuickNode for production, public for testing.
PRIVATE_RPC_URL_ARB=https://arb1.arbitrum.io/rpc

#  PayLinkFactoryV2 on Arbitrum One — same Nick's Method address as Base/Arc.
PAYLINK_FACTORY_V2_ARB=0x2268B8aad138a550FEf46C621756fEb26b587F78
VITE_FACTORY_V2_ARB=0x2268B8aad138a550FEf46C621756fEb26b587F78

#  Browser-side EVM RPCs for wallet clients and lightweight balance reads.
#  VITE_ prefix makes it available to Vite's client bundle.
VITE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_frontend_key
VITE_RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/your_frontend_key
VITE_RPC_URL_ARC=https://rpc.testnet.arc.network
VITE_RPC_URL_ARB=https://arb-mainnet.g.alchemy.com/v2/your_frontend_key
VITE_RPC_URL_HASHKEY=https://mainnet.hsk.xyz

# ─────────────────────────────────────────────────────────
#  Streampay Module — Arc Network
# ─────────────────────────────────────────────────────────
#  Deployed StreamVaultFactory on Arc Testnet (chainId 5042002).
#  Deploy with: npx hardhat run modules/streampay/scripts/deploy.ts --network arc
STREAM_FACTORY_ADDRESS=0xBAecf54084A0cB65b77a88cbDEf2b663Be71c61b

#  Browser-accessible factory address (VITE_ prefix exposes it to the frontend).
#  Used by StreamView to pre-compute vault addresses client-side via CREATE2.
#  Must match STREAM_FACTORY_ADDRESS exactly.
VITE_STREAM_FACTORY_ADDRESS=0xBAecf54084A0cB65b77a88cbDEf2b663Be71c61b

#  Optional: automatic recipient setup invites and agent reports.
#  Uses Resend. Configure the same verified mail.hashpaylink.com sender domain
#  used by Circle SMTP.
RESEND_API_KEY=re_your_resend_api_key_here
STREAM_INVITE_FROM_EMAIL=no-reply@mail.hashpaylink.com
STREAM_INVITE_FROM_NAME=StreamPay
AGENTIC_STREAMING_FROM_EMAIL=no-reply@mail.hashpaylink.com
AGENTIC_STREAMING_FROM_NAME=Hash PayLink Agent
ALERT_FROM_EMAIL=no-reply@mail.hashpaylink.com
STREAMPAY_BASE_URL=https://hashpaylink.com

#  Arc relayer key and RPC are shared with the InstantPay V2 relayer.
#  These are already declared above (RELAYER_PRIVATE_KEY_ARC, PRIVATE_RPC_URL_ARC).
#  The relay-stream handler falls back to RELAYER_PRIVATE_KEY if the ARC variant is unset.

# ─────────────────────────────────────────────────────────
#  Starknet Relayer (recover-starknet / setup-relayer)
# ─────────────────────────────────────────────────────────
#  OpenZeppelin Account deployed on Starknet Mainnet.
#  Fund with STRK for gas before calling /api/setup-starknet-relayer.
#  NEVER use the VITE_ prefix — these must stay server-side only.
STARKNET_RELAYER_ADDRESS=0x_your_starknet_relayer_address_here
STARKNET_RELAYER_PRIVATE_KEY=0x_your_starknet_relayer_private_key_here

#  OZ Account class hash — defaults to v0.8.1 if unset.
#  Only override if you deploy a different account class.
STARKNET_OZ_CLASS_HASH=0x061dac032f228abef9c6626f995015233097ae253a7f72d68552db02f2971b8f

#  Starknet RPC endpoint — defaults to public Lava node if unset.
#  Use a private endpoint (Infura / Blast) for higher rate limits.
STARKNET_RPC_URL=https://rpc.starknet.lava.build

# ─────────────────────────────────────────────────────────
#  Sweep Keeper (sweep-keeper / sweep)
# ─────────────────────────────────────────────────────────
#  Wallet that pays Base ETH gas for batch ghost-vault sweeps.
#  Does NOT need to hold USDC — it only submits the relay() call.
KEEPER_PRIVATE_KEY=0x_your_keeper_private_key_here

#  Secret passed as ?secret= query param to authenticate cron requests.
#  Set to any long random string (e.g. openssl rand -hex 32).
CRON_SECRET=your_random_cron_secret_here

#  Secret for admin-only operational endpoints such as Starknet setup/recovery.
#  Must be a long random string. If omitted, CRON_SECRET is used as fallback.
ADMIN_SECRET=your_random_admin_secret_here

#  Expected Hash PayLink treasury and Arc router factory used by guarded sweeps.
TREASURY_ADDRESS=0xcE5dF9e1115F81a2Fc2F65941B20B820d508e753
PAYMENT_ROUTER_FACTORY_ARC=0x70Dd5226eB973268263A9AcD8BC48b4E59E7beCA

#  Block number the PayLinkFactoryV2 was deployed at on Base mainnet.
#  Limits server-side dashboard/keeper event log scans.
FACTORY_FROM_BLOCK=45786000

# ---------------------------------------------------------------------------
#  Polymarket World Cup Scores
# ---------------------------------------------------------------------------
# Server-side only. Do not prefix the API key with VITE_.
# Recommended provider: sportmonks. Alternative: api-football.
POLY_STREAM_PROVIDER=sportmonks
POLY_STREAM_API_KEY=your_sportmonks_or_api_football_key
POLY_STREAM_LEAGUE_ID=732
POLY_STREAM_SEASON=2026
POLY_STREAM_FIXTURE_MODE=live
POLY_STREAM_CACHE_MS=60000
POLY_STREAM_LIMIT=12

# Exact Polymarket event/market links only. Search URLs should not be used here.
# Examples:
# {"USA vs Paraguay":"https://polymarket.com/event/exact-event","sportmonks:123456":"https://polymarket.com/event/exact-event"}
POLYMARKET_MATCH_URLS={}
