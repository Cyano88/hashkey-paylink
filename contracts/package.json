{
  "name": "@hashpaylink/contracts",
  "version": "1.0.0",
  "private": true,
  "description": "PaymentRouter + PaymentRouterFactory — deploy once per chain, route forever.",
  "scripts": {
    "compile":        "hardhat compile",
    "deploy:base":    "hardhat run scripts/deploy.ts --network base",
